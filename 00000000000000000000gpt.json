      "type": "n8n-nodes-base.youtube",
      "typeVersion": 2,
      "position": [2320, 220],
      "parameters": {
        "operation": "uploadVideo",
        "title": "={{$node[\"LocalizeLinks\"].json.title}}",
        "description": "={{$node[\"ParseCopy\"].json.copy + \"\\n\\nCompra: \" + ($node[\"LocalizeLinks\"].json.localized_links.find(x=>x.cc==='ES')?.url||'')}}",
        "privacyStatus": "public",
        "binaryProperty": "video"
      },
      "disabled": true,
      "credentials": { "youTubeOAuth2Api": { "id": "__CRED_YT__", "name": "YouTube OAuth" } }

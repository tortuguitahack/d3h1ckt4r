      "type": "n8n-nodes-base.reddit",
      "typeVersion": 2,
      "position": [2520, -20],
      "parameters": {
        "operation": "createPost",
        "sr": "={{$env.REDDIT_SUBREDDIT}}",
        "title": "={{$node[\"LocalizeLinks\"].json.title}}",

      },
      "credentials": { "redditOAuth2Api": { "id": "__CRED_REDDIT__", "name": "Reddit OAuth" } }
    },
    {
      "id": "MediumPost",
      "name": "Publish Medium (Article)",
      "type": "n8n-nodes-base.medium",
      "typeVersion": 2,
      "position": [2720, -20],
      "parameters": {
        "operation": "create",
        "contentFormat": "html",
        "title": "={{\"Guía rápida: \" + ($node[\"LocalizeLinks\"].json.title||'Producto Amazon')}}",
        "content": "={{\"<h2>Descubre: \" + ($node[\\\"LocalizeLinks\\\"].json.title||'Producto') + \"</h2><p>\" + $node[\\\"ParseCopy\\\"].json.copy.replace(/\\n/g,'<br>') + \"</p><p><strong>Compra:</strong> <a href='\" + ($node[\\\"LocalizeLinks\\\"].json.localized_links.find(x=>x.cc==='ES')?.url||'#') + \"'>ES</a> | <a href='\" + ($node[\\\"LocalizeLinks\\\"].json.localized_links.find(x=>x.cc==='US')?.url||'#') + \"'>US</a></p>\"}}",
        "publishStatus": "public"
      },
      "credentials": { "mediumApi": { "id": "__CRED_MEDIUM__", "name": "Medium API" } }
    },
    {
      "id": "MarkPosted",
      "name": "Mark as Posted (Sheets)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [2920, -20],
      "parameters": {
        "operation": "update",
        "sheetId": "1dOorilH3_wTs39Fdo01OHppmHa-tO27DYQDZZ0sXdSY",

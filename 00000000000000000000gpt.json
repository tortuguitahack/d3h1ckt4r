        "bodyParametersJson": "={\"text\": \"{{$node[\\\"ParseCopy\\\"].json.copy.slice(0,260)}}\\n[ES] {{ $node[\\\"LocalizeLinks\\\"].json.localized_links.find(x=>x.cc==='ES')?.url }}\"}"
      },

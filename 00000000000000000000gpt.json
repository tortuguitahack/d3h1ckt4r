        "bodyParametersJson": "={\"title\":\"{{$node[\\\"LocalizeLinks\\\"].json.title}}\",\"link\":\"{{ $node[\\\"LocalizeLinks\\\"].json.localized_links.find(x=>x.cc==='ES')?.url }}\",\"board_id\":\"{{$env.PINTEREST_BOARD_ID}}\",\"media_source\":{\"source_type\":\"image_url\",\"url\":\"{{$node[\\\"SelectImage\\\"].json.image_url}}\"}}"
      },
      "disabled": true
    }
  ],

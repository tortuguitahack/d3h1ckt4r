{
  "name": "Amazon_Affiliates_Global_HyperPublisher",
  "nodes": [
    {
      "id": "CronStart",
      "name": "Start (Cron @hourly)",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [120, -20],
      "parameters": {
        "triggerTimes": { "item": [{ "mode": "everyHour" }] }
      }
    },
    {
      "id": "SheetRead",
      "name": "Read Products (Google Sheets)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [320, -20],
      "parameters": {
        "operation": "read",
        "sheetId": "1dOorilH3_wTs39Fdo01OHppmHa-tO27DYQDZZ0sXdSY",
        "range": "Products!A:F",
        "options": { "valueRenderMode": "UNFORMATTED_VALUE", "useFirstRowAsHeader": true }
      },
      "credentials": { "googleApi": { "id": "__CRED_GOOGLE__", "name": "Google API" } }
    },
    {
      "id": "FilterUnposted",
      "name": "Filter Not Posted",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [520, -20],
      "parameters": {
        "conditions": {
          "boolean": [{ "value1": "={{$json[\"posted\"] !== \"Sí\" && $json[\"posted\"] !== \"YES\"}}" }]
        }
      }
    },
    {
      "id": "Batch",
      "name": "Split in Batches (50)",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 1,
      "position": [720, -20],
      "parameters": { "batchSize": 50 }
    },
    {
      "id": "LocalizeLinks",
      "name": "Build Localized Links (10 Countries)",
      "type": "n8n-nodes-base.function",
      "typeVersion": 2,
      "position": [920, -20],
      "parameters": {
        "functionCode": "const asin = $json.asin || ($json.ASIN||'').trim();\nconst base = ($json.base_url||'').trim();\nconst title = $json.title||'';\nconst tag = 'diegoedgard02-20';\nconst markets = [\n  {cc:'US',tld:'com'}, {cc:'UK',tld:'co.uk'}, {cc:'DE',tld:'de'}, {cc:'FR',tld:'fr'},\n  {cc:'ES',tld:'es'}, {cc:'IT',tld:'it'}, {cc:'JP',tld:'co.jp'}, {cc:'CA',tld:'ca'},\n  {cc:'MX',tld:'com.mx'}, {cc:'AU',tld:'com.au'}\n];\nfunction linkFor(tld){\n  if (base && base.includes('amazon.')) {\n    const u = new URL(base);\n    u.searchParams.set('tag', tag);\n    return u.toString();\n  }\n  if (!asin) return null;\n  return `https://www.amazon.${tld}/dp/${asin}?tag=${tag}`;\n}\nconst localized = markets.map(m=>({ cc:m.cc, url: linkFor(m.tld)})).filter(x=>!!x.url);\nreturn [{...$json, title, asin, localized_links: localized}];"
      }
    },
    {
      "id": "CopyLLM",
      "name": "Generate Copy (OpenRouter LLM)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1120, -20],
      "parameters": {
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "method": "POST",
        "jsonParameters": true,
        "options": { "timeout": 90000 },
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParametersJson": "={\"Authorization\":\"Bearer {{$env.OPENROUTER_API_KEY}}\",\"HTTP-Referer\":\"{{$env.SITE_URL||'https://atechany.com'}}\",\"X-Title\":\"n8n-Amazon-Affiliates\"}",
        "bodyParametersJson": "={\n  \"model\": \"{{$env.OPENROUTER_MODEL||'anthropic/claude-3-haiku'}}\",\n  \"temperature\": 0.7,\n  \"messages\": [\n    {\"role\":\"system\",\"content\":\"Eres una estratega de marketing senior. Redacta copy persuasivo ético, directo a conversión, estilo breve y claro, usando patrones seguros: gancho visual (VAK), ritmo, prueba social y CTA. Evita afirmaciones engañosas. Idioma: español neutro.\"},\n    {\"role\":\"user\",\"content\": \"Producto: {{$json.title}}\\nCategoría: {{$json.category||''}}\\nPrecio: {{$json.price||''}}\\nMercados: {{ $json.localized_links.map(l=>l.cc).join(', ') }}\\nInstrucción: 1) 3 titulares (máx 60 chars). 2) Un texto corto ‘AIDA’ (80-120 palabras). 3) 5 hashtags. 4) 3 variaciones de CTA. 5) 1 guion de video 15s con escena de mujer presentando el producto (no sexualizar, foco en beneficios), con acotaciones de cámara y texto on-screen. 6) 1 descripción para Pinterest. 7) 1 snippet para Reddit. 8) Incluye la URL de ES y US desde localized_links al final con etiquetas [ES] y [US].\"}\n  ]\n}"
      },
      "credentials": { "httpHeaderAuth": { "id": "__CRED_OPENROUTER__", "name": "OpenRouter API" } }
    },
    {
      "id": "ParseCopy",
      "name": "Parse Copy JSON",
      "type": "n8n-nodes-base.function",
      "typeVersion": 2,
      "position": [1320, -20],
      "parameters": {
        "functionCode": "const raw = items[0].json;\nconst text = raw.choices?.[0]?.message?.content || '';\nreturn [{ copy:text }];"
      }
    },
    {
      "id": "FindImage",
      "name": "Find Image (Pexels)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1520, -20],
      "parameters": {
        "url": "https://api.pexels.com/v1/search",
        "method": "GET",
        "sendQuery": true,
        "qs": {
          "query": "woman presenting {{$node[\"LocalizeLinks\"].json[\"title\"]||'product'}} studio",
          "per_page": 1,
          "orientation": "landscape"
        },
        "sendHeaders": true,
        "headerParametersJson": "={\"Authorization\":\"{{$env.PEXELS_API_KEY}}\"}"
      }
    },
    {
      "id": "SelectImage",
      "name": "Select Image URL",
      "type": "n8n-nodes-base.function",
      "typeVersion": 2,
      "position": [1720, -20],
      "parameters": {
        "functionCode": "const photos = $json.photos || [];\nconst url = photos[0]?.src?.large || photos[0]?.src?.original || null;\nreturn [{ image_url: url }];"
      }
    },
    {
      "id": "BuildTTS",
      "name": "TTS (VoiceRSS, es-ES female)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1920, -20],
      "parameters": {
        "url": "https://api.voicerss.org/",
        "method": "GET",
        "responseFormat": "file",
        "jsonParameters": false,
        "sendQuery": true,
        "qs": {
          "key": "={{$env.VOICERSS_API_KEY}}",
          "hl": "es-es",
          "v": "Isabella",
          "src": "={{$node[\"ParseCopy\"].json.copy}}",
          "r": "0",
          "c": "MP3",
          "f": "44khz_16bit_stereo"
        }
      }
    },
    {
      "id": "AssembleVideo",
      "name": "Assemble Short Video (Shotstack) [Optional]",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [2120, -20],
      "parameters": {
        "url": "https://api.shotstack.io/stage/render",
        "method": "POST",
        "jsonParameters": true,
        "sendHeaders": true,
        "headerParametersJson": "={\"x-api-key\":\"{{$env.SHOTSTACK_API_KEY}}\",\"Content-Type\":\"application/json\"}",
        "bodyParametersJson": "={\n  \"timeline\": {\n    \"soundtrack\": {\"src\": \"data:audio/mp3;base64,{{$binary.data? $binary.data.toString('base64'):''}}\"},\n    \"tracks\": [{\"clips\": [\n      {\"asset\": {\"type\":\"title\",\"text\":\"{{$node[\\\"LocalizeLinks\\\"].json.title || 'Producto destacado'}}\",\"style\":\"minimal\"},\"start\":0,\"length\":2},\n      {\"asset\": {\"type\":\"image\",\"src\":\"{{$node[\\\"SelectImage\\\"].json.image_url}}\"},\"start\":0,\"length\":15},\n      {\"asset\": {\"type\":\"title\",\"text\":\"Compra ahora\",\"style\":\"minimal\"},\"start\":12,\"length\":3}\n    ]}]\n  },\n  \"output\": {\"format\":\"mp4\",\"resolution\":\"sd\"}\n}"
      }
    },
    {
      "id": "TelegramPhoto",
      "name": "Publish Telegram (Photo+Caption)",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [2320, -20],
      "parameters": {
        "chatId": "={{$env.TELEGRAM_CHAT_ID}}",
        "operation": "sendPhoto",
        "additionalFields": {
          "caption": "={{$node[\"ParseCopy\"].json.copy + \"\\n\\n[ES] \" + $node[\"LocalizeLinks\"].json.localized_links.find(x=>x.cc==='ES')?.url + \"\\n[US] \" + $node[\"LocalizeLinks\"].json.localized_links.find(x=>x.cc==='US')?.url}}",
          "disableNotification": true
        },
        "binaryProperty": "data"
      },
      "credentials": { "telegramApi": { "id": "__CRED_TELEGRAM__", "name": "Telegram Bot" } }
    },
    {
      "id": "RedditPost",

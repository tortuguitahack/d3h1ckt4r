        "range": "Products!A:G",
        "keyRow": 1,
        "options": { "valueInputMode": "RAW", "updateAllMatches": true, "rawData": true }
      },
      "credentials": { "googleApi": { "id": "__CRED_GOOGLE__", "name": "Google API" } }
    }
  ],

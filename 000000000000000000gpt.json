        "headerParametersJson": "={\"Authorization\":\"Bearer {{$env.TIKTOK_TOKEN}}\"}",
        "bodyParametersJson": "={\"caption\":\"{{$node['parse_copy'].json.copy.titles?.[0] || ''}}\",\"video_url\":\"{{$json.video_url || ''}}\"}"
      },

        "method": "POST",
        "jsonParameters": true,
        "sendHeaders": true,
        "headerParametersJson": "={\"Authorization\":\"Bearer {{$env.TWITTER_BEARER}}\",\"Content-Type\":\"application/json\"}",
        "bodyParametersJson": "={\"text\":\"{{$node['parse_copy'].json.copy.titles?.[0] || ''}}\\n{{$node['parse_copy'].json.url}}\"}"
      },
      "disabled": true
    },
    {
      "id": "fbpage",

      "type": "n8n-nodes-base.youtube",
      "typeVersion": 2,
      "position": [2720, -320],
      "parameters": {
        "operation": "uploadVideo",
        "title": "={{$node['build_links'].json.title}}",
        "description": "={{$node['parse_copy'].json.copy.text_aida + '\\n\\n' + $node['parse_copy'].json.url}}",

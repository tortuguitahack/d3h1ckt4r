        "headerParametersJson": "={\"Authorization\":\"Bearer {{$env.PINTEREST_TOKEN}}\",\"Content-Type\":\"application/json\"}",
        "bodyParametersJson": "={\"title\":\"{{$node['build_links'].json.title}}\",\"link\":\"{{$node['parse_copy'].json.url}}\",\"board_id\":\"{{$env.PINTEREST_BOARD_ID}}\",\"media_source\":{\"source_type\":\"image_url\",\"url\":\"{{$node['select_image'].json.image_url}}\"}}"
      },

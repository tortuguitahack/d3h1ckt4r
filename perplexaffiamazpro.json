{
  "name": "Affiliate Amazon Marketing Flow Advanced Validated",
  "nodes": [
    {
      "name": "Webhook Lead Capture",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": ,
      "parameters": {
        "httpMethod": "POST",
        "path": "lead-capture",
        "responseCode": 200
      }
    },
    {
      "name": "Set Clean Lead Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": ,
      "parameters": {
        "keepOnlySet": true,
        "values": {
          "email": "={{ $json.email ? $json.email.trim().toLowerCase() : '' }}",
          "interest": "={{ $json.interest ? $json.interest.trim() : '' }}",
          "affiliateLink": "={{ $json.affiliateLink ? $json.affiliateLink.trim() : '' }}",
          "timestamp": "={{ $now }}"
        }
      }
    },
    {
      "name": "Validate Required Fields",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": ,
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.email}}",
              "operation": "isNotEmpty"
            },
            {
              "value1": "={{$json.interest}}",
              "operation": "isNotEmpty"
            },
            {
              "value1": "={{$json.affiliateLink}}",
              "operation": "isNotEmpty"
            }
          ]
        }
      }
    },
    {
      "name": "Generate Content Outline",
      "type": "n8n-nodes-base.openai",
      "typeVersion": 1,
      "position": ,
      "parameters": {
        "model": "gpt-3.5-turbo",
        "prompt": "Genera un outline atractivo para promocionar el producto elegido: {{ $json.interest }} usando beneficios y llamada a la acción."
      }
    },
    {
      "name": "Generate Persuasive Blog Post",
      "type": "n8n-nodes-base.openai",
      "typeVersion": 1,
      "position": [1000],
      "parameters": {
        "model": "gpt-3.5-turbo",
        "prompt": "Escribe un artículo persuasivo basado en el outline anterior, incluye el enlace de afiliado: {{ $json.affiliateLink }}. Usa técnicas de persuasión e hipnosis conversacional para ventas masivas."
      }
    },
    {
      "name": "Append to Google Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 1,
      "position": [1200],
      "parameters": {
        "operation": "append",
        "sheetId": "{{GOOGLE_SHEETS_ID}}",
        "range": "Sales!A:D",
        "values": [
          [
            "={{ $json.email }}",
            "={{ $json.interest }}",
            "={{ $json.affiliateLink }}",
            "={{ $json.timestamp }}"
          ]
        ]
      }
    },
    {
      "name": "Send Sales Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 1,
      "position": [1400],
      "parameters": {
        "toEmail": "={{ $json.email }}",
        "subject": "Tu guía profesional sobre {{ $json.interest }}",
        "text": "{{ $json.blogPost }}\n\n👉 Accede aquí: {{ $json.affiliateLink }}"
      }
    }
  ],
  "connections": {
    "Webhook Lead Capture": {
      "main": [[
        {
          "node": "Set Clean Lead Data",
          "type": "main",
          "index": 0
        }
      ]]
    },
    "Set Clean Lead Data": {
      "main": [[
        {
          "node": "Validate Required Fields",
          "type": "main",
          "index": 0
        }
      ]]
    },
    "Validate Required Fields": {
      "main": [
        [
          {
            "node": "Generate Content Outline",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Generate Content Outline": {
      "main": [[
        {
          "node": "Generate Persuasive Blog Post",
          "type": "main",
          "index": 0
        }
      ]]
    },
    "Generate Persuasive Blog Post": {
      "main": [[
        {
          "node": "Append to Google Sheets",
          "type": "main",
          "index": 0
        }
      ]]
    },
    "Append to Google Sheets": {
      "main": [[
        {
          "node": "Send Sales Email",
          "type": "main",
          "index": 0
        }
      ]]
    }
  }
}
